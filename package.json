{
  "name": "ootprebuildtest",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "prebuild": "DEBUG=expo:* expo prebuild --clean --platform ios --template ./template/tv-template.tgz --no-install",
    "prebuild:tv": "DEBUG=expo:* expo prebuild --clean --platform tvos --template ./template/tv-template.tgz",
    "ios:pod-install": "(cd ios; pod install --verbose; cd -)",
    "tvos:pod-install": "(cd tvos; pod install --verbose; cd -)",
    "tvos:debug:build": "set -o pipefail && xcodebuild -workspace tvos/OOTPrebuildTest.xcworkspace -scheme OOTPrebuildTest -configuration Debug -sdk appletvsimulator -arch arm64 -derivedDataPath tvos/build | pnpm excpretty",
    "tvos:debug:install": "xcrun simctl install booted tvos/build/Build/Products/Debug-appletvsimulator/OOTPrebuildTest.app",
    "tvos:release:build": "set -o pipefail && xcodebuild -workspace tvos/OOTPrebuildTest.xcworkspace -scheme OOTPrebuildTest -configuration Release -sdk appletvsimulator -arch arm64 -derivedDataPath tvos/build | pnpm excpretty",
    "tvos:release:install": "xcrun simctl install booted tvos/build/Build/Products/Release-appletvsimulator/OOTPrebuildTest.app",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "56.0.6-canary-20260606-4d4666c",
    "expo-build-properties": "56.0.16-canary-20260606-4d4666c",
    "expo-constants": "56.0.17-canary-20260606-4d4666c",
    "expo-dev-client": "56.0.17-canary-20260606-4d4666c",
    "expo-font": "56.0.6-canary-20260606-4d4666c",
    "expo-glass-effect": "56.0.5-canary-20260606-4d4666c",
    "expo-image": "56.0.10-canary-20260606-4d4666c",
    "expo-linear-gradient": "56.0.5-canary-20260606-4d4666c",
    "expo-linking": "56.0.13-canary-20260606-4d4666c",
    "expo-router": "56.2.8-canary-20260606-4d4666c",
    "expo-splash-screen": "56.0.11-canary-20260606-4d4666c",
    "expo-status-bar": "56.0.5-canary-20260606-4d4666c",
    "expo-symbols": "56.0.6-canary-20260606-4d4666c",
    "expo-system-ui": "56.0.6-canary-20260606-4d4666c",
    "expo-web-browser": "56.0.6-canary-20260606-4d4666c",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0-rc.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-tvos": "0.86.0-0rc3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
